# ============================================================
# .env.example — Variáveis de ambiente para docker-compose
# ============================================================
# Copie para .env e ajuste os valores:
#   cp .env.example .env
# ============================================================

# Senha do SQL Server (mínimo 8 chars, maiúscula+minúscula+número+especial)
DB_PASSWORD=EcoTurismo@2024!

# Chave JWT (mínimo 32 caracteres)
JWT_SECRET=SuaChaveSecretaComPeloMenos32CaracteresParaProducao!

# URL do frontend (CORS)
FRONTEND_URL=http://localhost:5173

# Azure Blob Storage (deixe vazio para usar Azurite local)
AZURE_BLOB_CONNECTION=

# SSL — Certificados para Nginx (default: nginx/ssl/)
# SSL_CERT_PATH=./nginx/ssl/cert.pem
# SSL_KEY_PATH=./nginx/ssl/key.pem
